model RentalRequest {
    id             String              @id @default(uuid())
    status         RentalRequestStatus @default(PENDING)
    moveInDate     DateTime
    durationMonths Int                 @default(1)
    endDate        DateTime?
    tenantId       String
    tenant         User                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    propertyId     String
    property       Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
    createdAt      DateTime            @default(now())
    updatedAt      DateTime            @updatedAt
    payment        Payment?
    review         Review?

    // A partial unique index (one OPEN request — PENDING/APPROVED/ACTIVE —
    // per tenant+property) is defined in migration
    // 20260710130000_rental_open_request_unique. Prisma cannot represent a
    // partial (WHERE-filtered) unique index in the schema, so it lives at the
    // DB level. Terminal states (REJECTED/COMPLETED) are intentionally allowed
    // to repeat, so repeat rentals and repeat rejections work.
    @@index([status, endDate])
    @@map("rental_requests")
}
